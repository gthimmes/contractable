# Dev database: SQLite for zero-infra local runs.
# For production, switch the datasource provider in prisma/schema.prisma to
# "postgresql" and set this to your Postgres connection string, e.g.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/contractable?schema=public"
DATABASE_URL="file:./dev.db"

# Base URL used to build signing links.
APP_BASE_URL="http://localhost:3000"

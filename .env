# Dev database: SQLite for zero-infra local runs.
# For production, switch the datasource provider in prisma/schema.prisma to
# "postgresql" and set this to your Postgres connection string, e.g.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/contractable?schema=public"
DATABASE_URL="file:./dev.db"

# Base URL used to build signing links.
APP_BASE_URL="http://localhost:3000"

# Real email delivery (optional). When SMTP_HOST is set, every notification is
# ALSO sent over SMTP (the in-app outbox always records it, with the delivery
# outcome). Port 587 uses STARTTLS when the server offers it; 465 is implicit TLS.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="apikey-or-username"
# SMTP_PASS="secret"
# SMTP_FROM="Contractable <no-reply@example.com>"

# Google SSO (optional). When both are set, the login page offers
# "Sign in with Google". The Google account's verified email must match an
# existing user — accounts are never auto-created. Authorized redirect URI:
#   {APP_BASE_URL}/auth/google/callback
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="..."

# Generic OIDC SSO (optional) — Okta, Azure AD / Entra, Auth0, Keycloak, etc.
# Endpoints are resolved from {OIDC_ISSUER}/.well-known/openid-configuration.
# Authorized redirect URI: {APP_BASE_URL}/auth/oidc/callback
# OIDC_ISSUER="https://your-org.okta.com"
# OIDC_CLIENT_ID="..."
# OIDC_CLIENT_SECRET="..."
# OIDC_NAME="Okta"
